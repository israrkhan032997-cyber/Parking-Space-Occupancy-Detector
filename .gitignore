# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Model weights & training artefacts ────────────────────────────────────────
# Keep models/best.pt (tracked via Git LFS or committed directly if small)
# Exclude the unpacked SafeTensors/zipfile directories Ultralytics creates
models/best/
models/yolov8n/
models/yolov8n.pt
*.pt.tmp

# Ultralytics training run outputs (can be large)
runs/

# ── Logs & temp files ──────────────────────────────────────────────────────────
*.log
pip_install.log
train.log
download.log
download2.log

# ── Dataset — keep labels + structure, ignore copied image splits ─────────────
# Raw source images at project root level are committed
# But train/val copies are regenerated by convert_annotations.py
dataset/images/train/*.png
dataset/images/train/*.jpg
dataset/images/train/*.jpeg
dataset/images/val/*.png
dataset/images/val/*.jpg
dataset/images/val/*.jpeg

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Streamlit cache ───────────────────────────────────────────────────────────
.streamlit/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
